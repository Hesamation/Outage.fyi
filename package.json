{
  "name": "outage-fyi",
  "version": "0.1.0",
  "description": "Real uptime data for every cloud service. Scrape, normalize, and score public status pages.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "scrape": "bun run bin/scrape.ts",
    "serve": "bun run bin/serve.ts",
    "score": "bun run bin/score.ts",
    "export": "bun run bin/export.ts",
    "dev": "bun run --watch bin/serve.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "uptime",
    "status-page",
    "incidents",
    "reliability",
    "monitoring",
    "cloud",
    "scraper"
  ],
  "author": "Hesamation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hesamation/outage-fyi"
  },
  "homepage": "https://github.com/Hesamation/outage-fyi#readme",
  "bugs": {
    "url": "https://github.com/Hesamation/outage-fyi/issues"
  }
}
